# ============================================================
# Mock Mode — set true to run the full pipeline without API keys
# All LLM calls (generation + repair) return deterministic fake responses.
# Every deterministic stage runs normally. Ideal for local dev and CI tests.
# ============================================================
MOCK_MODE=false

# ============================================================
# Provider selection — choose one: openai | gemini
# (ignored when MOCK_MODE=true — no API key needed)
# ============================================================
LLM_PROVIDER=openai

# ============================================================
# Provider fallback and retry
#
# FALLBACK_PROVIDER: if the primary provider fails all retries,
#   the pipeline automatically retries with this provider.
#   Leave empty to disable (default).
#   Example: LLM_PROVIDER=openai + FALLBACK_PROVIDER=gemini
#            → tries OpenAI first, falls back to Gemini on failure.
#
# LLM_RETRY_ATTEMPTS: how many times to try each provider before
#   moving to the next one. 1 = no retry (default). 2 = one retry.
#
# If every configured provider fails, the pipeline returns an empty
# response rather than crashing (logged at ERROR level).
# ============================================================
FALLBACK_PROVIDER=
LLM_RETRY_ATTEMPTS=1

# ============================================================
# API keys — set the key for your chosen provider
# ============================================================
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ============================================================
# Model selection
# Defaults are set automatically from LLM_PROVIDER.
# Override any individual role here if needed.
#
# OpenAI defaults:
#   INTENT_MODEL=gpt-4o-mini
#   STRATEGY_MODEL=gpt-4o-mini
#   GENERATE_MODEL=gpt-4o-mini
#   REPAIR_MODEL=gpt-4o-mini
#
# Gemini defaults:
#   INTENT_MODEL=gemini-2.5-flash
#   STRATEGY_MODEL=gemini-2.5-flash
#   GENERATE_MODEL=gemini-2.5-pro
#   REPAIR_MODEL=gemini-2.5-pro
# ============================================================
# INTENT_MODEL=
# STRATEGY_MODEL=
# GENERATE_MODEL=
# REPAIR_MODEL=

# Temperature controls
INTENT_TEMPERATURE=0.0
STRATEGY_TEMPERATURE=0.2
GENERATE_TEMPERATURE=0.7
REPAIR_TEMPERATURE=0.3

# Quality validation thresholds
VALIDATION_PASS_THRESHOLD=75
AUTO_REPAIR_THRESHOLD=55
MAX_REPAIR_ATTEMPTS=2

# Humanization threshold
# Score 0-100 from the humanization validator (specificity + tension + originality + experience).
# Below this → deterministic transition removal + targeted LLM humanization pass.
HUMANIZATION_REPAIR_THRESHOLD=60
